# Copy to .env for local private configuration.
# .env is ignored by git.

# Your own sender_username/wxid in WeLive JSONL exports.
SIMP_ME_WXID=wxid_me

# Local-only private memory and output folders.
SIMP_CRUSH_ROOT=local_data/crushes
SIMP_WELIVE_RECORD_DIR=local_data/welive-records
SIMP_OUTPUT_DIR=local_outputs

